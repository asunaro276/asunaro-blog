---
import { Article } from "/domain/models/article/Article";

type Props = {
  article: Article;
};

const { article } = Astro.props;

let imageSrc: string;
if (article.coverImage.src instanceof URL) {
  imageSrc = article.coverImage.src.href;
} else if (typeof article.coverImage.src === 'object' && (article.coverImage.src as any)?.src) {
  imageSrc = (article.coverImage.src as any).src;
} else if (typeof article.coverImage.src === 'string') {
  imageSrc = article.coverImage.src;
} else {
  imageSrc = '/images/default-cover.jpg';
}
---

<section
  data-testid="hero-section"
  style="background-color: var(--bg-2); border-bottom: 1px solid var(--rule); padding: 48px 0;"
>
  <div
    style="max-width: 1200px; margin: 0 auto; padding: 0 32px; display: grid; grid-template-columns: 1.15fr 1fr; gap: 48px; align-items: center;"
  >
    <!-- テキスト情報 -->
    <div style="display: flex; flex-direction: column; gap: 16px;">
      <span
        data-featured-label
        class="font-mono"
        style="font-size: 11px; font-weight: 600; letter-spacing: 0.18em; color: var(--accent); text-transform: uppercase;"
      >
        Featured
      </span>

      <div style="display: flex; gap: 12px; align-items: center;">
        <span style="font-size: 12px; font-weight: 500; color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase;">
          {article.category.name}
        </span>
        <span class="font-mono" style="font-size: 12px; color: var(--fg-3);">
          {Article.formatDate(article.publishedAt)}
        </span>
      </div>

      <h2
        data-hero-title
        class="font-serif-jp"
        style="font-size: 52px; font-weight: 700; line-height: 1.3; color: var(--fg); margin: 0;"
      >
        {article.title}
      </h2>

      {article.description && (
        <p style="font-size: 15px; line-height: 1.8; color: var(--fg-2); margin: 0;">
          {article.description}
        </p>
      )}

      {article.tags.length > 0 && (
        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
          {article.tags.map(tag => (
            <span
              data-tag-chip
              style="display: inline-block; padding: 4px 12px; border-radius: 99px; background: var(--bg); border: 1px solid var(--rule-2); font-size: 12px; color: var(--fg-2);"
            >
              #{tag.name}
            </span>
          ))}
        </div>
      )}

      <a
        href={`/blog/${article.articleId}`}
        style="display: inline-flex; align-items: center; gap: 4px; font-size: 14px; font-weight: 500; color: var(--accent); text-decoration: underline; text-underline-offset: 3px;"
      >
        本文を読む →
      </a>
    </div>

    <!-- カバー画像 -->
    <div
      data-hero-image
      style="aspect-ratio: 3/2; overflow: hidden; border-radius: 8px; background: var(--bg-3);"
    >
      <img
        src={imageSrc}
        alt={article.coverImage.altText ?? article.title}
        style="width: 100%; height: 100%; object-fit: cover;"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    section > div {
      grid-template-columns: 1fr !important;
    }
    h2[data-hero-title] {
      font-size: 32px !important;
    }
  }
</style>
