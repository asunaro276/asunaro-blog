---
import { Article } from "/domain/models/article/Article";

type Props = {
  article: Article;
};

const { article } = Astro.props;

let imageSrc: string;
if (article.coverImage.src instanceof URL) {
  imageSrc = article.coverImage.src.href;
} else if (typeof article.coverImage.src === 'object' && (article.coverImage.src as any)?.src) {
  imageSrc = (article.coverImage.src as any).src;
} else if (typeof article.coverImage.src === 'string') {
  imageSrc = article.coverImage.src;
} else {
  imageSrc = '/images/default-cover.jpg';
}
---

<a
  href={`/blog/${article.articleId}`}
  class="post-card"
  style="display: block; text-decoration: none; border-radius: 8px; overflow: hidden; background: var(--bg); border: 1px solid var(--rule); transition: transform 0.2s ease, box-shadow 0.2s ease; cursor: pointer;"
>
  <!-- カバー画像 4:3 -->
  <div
    data-card-image
    style="aspect-ratio: 4/3; overflow: hidden; background: var(--bg-3);"
  >
    <img
      src={imageSrc}
      alt={article.coverImage.altText ?? article.title}
      style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;"
      loading="lazy"
    />
  </div>

  <!-- テキスト情報 -->
  <div style="padding: 16px;">
    <!-- カテゴリ + 日付 -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
      <span
        data-card-category
        style="font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent);"
      >
        {article.category.name}
      </span>
      <span
        data-card-date
        class="font-mono"
        style="font-size: 11px; color: var(--fg-3);"
      >
        {Article.formatDate(article.publishedAt)}
      </span>
    </div>

    <!-- 見出し -->
    <h3
      data-card-title
      class="font-serif-jp"
      style="font-size: 17px; font-weight: 600; line-height: 1.5; color: var(--fg); margin: 0 0 8px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
    >
      {article.title}
    </h3>

    <!-- 説明文 -->
    {article.description && (
      <p style="font-size: 13px; line-height: 1.6; color: var(--fg-2); margin: 0 0 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
        {article.description}
      </p>
    )}

    <!-- タグ -->
    {article.tags.length > 0 && (
      <div style="display: flex; flex-wrap: wrap; gap: 6px;">
        {article.tags.slice(0, 3).map(tag => (
          <span
            data-card-tag
            style="font-size: 11px; color: var(--fg-3);"
          >
            #{tag.name}
          </span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px oklch(0 0 0 / 0.08);
  }
</style>
