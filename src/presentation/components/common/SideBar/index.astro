---
import { ArchiveHeatmap } from "./ArchiveHeatmap";
import SideProfile from "./SideProfile/index.astro";
import SideTags from "./SideTags/index.astro";
import type { YearMonth } from "/domain/models/article/yearmonth/YearMonth";
import type { Tag } from "/domain/models/article/tag/Tag";
import type { Heading } from "/domain/models/article/heading/Heading";

type Props = {
  tableOfContents?: Heading[];
  tags: Tag[];
  yearmonths: YearMonth[];
};
const props = Astro.props;

// client:load コンポーネントへはシリアライズ可能なプレーンオブジェクトで渡す
const heatmapData = props.yearmonths.map(ym => ({
  year: ym.year,
  month: ym.month,
  count: ym.count,
  value: ym.value,
}));
---

<div
  data-sidebar
  style="border-left: 1px solid var(--rule); padding-left: 36px; height: 100%;"
>
  <div style="padding: 8px 0 28px;">
    <SideProfile />
  </div>
  <div style="padding: 24px 0; border-top: 1px solid var(--rule);">
    <SideTags tags={props.tags} />
  </div>
  <div style="padding: 24px 0; border-top: 1px solid var(--rule);">
    <ArchiveHeatmap yearmonths={heatmapData} client:load />
  </div>
</div>
